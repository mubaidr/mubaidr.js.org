[{"data":1,"prerenderedAt":312},["ShallowReactive",2],{"content-/blog/2-my-vscode-setup":3,"home":187,"content-query-qKssHOB7DJ":203},{"article":4,"surround":181},{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"headline":11,"abstract":12,"date":13,"dateUpdated":8,"author":14,"authorUrl":15,"socialImage":16,"body":22,"_type":175,"_id":176,"_source":177,"_file":178,"_stem":179,"_extension":180},"/blog/2-my-vscode-setup","blog",false,"","My VSCode Setup | Blog","Explore my minimalist VSCode setup featuring the Minimal Mist theme and settings for a clean, distraction-free coding environment.","My VSCode Setup","Discover how the Minimal Mist theme and custom VSCode settings create a clean and focused coding environment.","2024-07-17T12:00:00","Muhammad Ubaid Raza","https://mubaidr.js.org/",{"src":17,"mime":18,"alt":19,"width":20,"height":21},"/img/blog/2-my-vscode-setup/typescript-dark.png","png","Workplace Screenshot",1200,630,{"type":23,"children":24,"toc":162},"root",[25,33,39,46,53,67,73,78,84,89,95,100,106,111,116,122,127,134,143,149],{"type":26,"tag":27,"props":28,"children":30},"element","h1",{"id":29},"my-vscode-setup",[31],{"type":32,"value":11},"text",{"type":26,"tag":34,"props":35,"children":36},"p",{},[37],{"type":32,"value":38},"Hello, fellow developers! I’m Muhammad Ubaid Raza, and I want to share my latest VSCode setup with you. I've crafted this environment to be as minimalist and distraction-free as possible, and I call it Minimal Mist. This theme and setup have greatly enhanced my coding experience, and I hope it can do the same for you.",{"type":26,"tag":40,"props":41,"children":43},"h2",{"id":42},"features-of-minimal-mist",[44],{"type":32,"value":45},"Features of Minimal Mist",{"type":26,"tag":47,"props":48,"children":50},"h3",{"id":49},"subtle-background",[51],{"type":32,"value":52},"Subtle Background",{"type":26,"tag":34,"props":54,"children":55},{},[56,58,65],{"type":32,"value":57},"I chose a soft and soothing background color ",{"type":26,"tag":59,"props":60,"children":62},"code",{"className":61},[],[63],{"type":32,"value":64},"#f6f5f0",{"type":32,"value":66},". This subtle hue reduces eye strain and creates a calm coding environment, perfect for long coding sessions.",{"type":26,"tag":47,"props":68,"children":70},{"id":69},"shadow-free-design",[71],{"type":32,"value":72},"Shadow-Free Design",{"type":26,"tag":34,"props":74,"children":75},{},[76],{"type":32,"value":77},"In my quest for a cleaner interface, I disabled shadows. This makes the interface feel lighter and less cluttered, allowing me to focus more on my code.",{"type":26,"tag":47,"props":79,"children":81},{"id":80},"streamlined-borders",[82],{"type":32,"value":83},"Streamlined Borders",{"type":26,"tag":34,"props":85,"children":86},{},[87],{"type":32,"value":88},"Borders can often add unnecessary visual noise, so I simplified, minimized, or removed them. This provides a clean and focused workspace that helps keep distractions at bay.",{"type":26,"tag":47,"props":90,"children":92},{"id":91},"clean-look",[93],{"type":32,"value":94},"Clean Look",{"type":26,"tag":34,"props":96,"children":97},{},[98],{"type":32,"value":99},"Overall, the goal is a refined, distraction-free interface that lets me concentrate on what matters most - the code.",{"type":26,"tag":47,"props":101,"children":103},{"id":102},"unified-design",[104],{"type":32,"value":105},"Unified Design",{"type":26,"tag":34,"props":107,"children":108},{},[109],{"type":32,"value":110},"The dark theme maintains the same streamlined, shadow-free design and simplified borders for a cohesive look.",{"type":26,"tag":34,"props":112,"children":113},{},[114],{"type":32,"value":115},"Minimal Mist, both in light and dark variants, is perfect for developers who value a clean, minimalist aesthetic.",{"type":26,"tag":40,"props":117,"children":119},{"id":118},"preview",[120],{"type":32,"value":121},"Preview",{"type":26,"tag":34,"props":123,"children":124},{},[125],{"type":32,"value":126},"Here’s a preview of what you can expect:",{"type":26,"tag":128,"props":129,"children":131},"h4",{"id":130},"typescript",[132],{"type":32,"value":133},"Typescript",{"type":26,"tag":34,"props":135,"children":136},{},[137],{"type":26,"tag":138,"props":139,"children":142},"img",{"alt":140,"src":141},"Typescript Light","/img/blog/2-my-vscode-setup/typescript-light.png",[],{"type":26,"tag":40,"props":144,"children":146},{"id":145},"my-vscode-settings",[147],{"type":32,"value":148},"My VsCode Settings",{"type":26,"tag":34,"props":150,"children":151},{},[152,154,160],{"type":32,"value":153},"To further enhance the workspace setup, I use the following settings to reduce clutter and make my workspace even more minimal without sacrificing any functionality. You can add these settings to your ",{"type":26,"tag":59,"props":155,"children":157},{"className":156},[],[158],{"type":32,"value":159},"settings.json",{"type":32,"value":161}," file in VSCode to achieve the same look as in the screenshots above:",{"title":8,"searchDepth":163,"depth":163,"links":164},2,[165,173,174],{"id":42,"depth":163,"text":45,"children":166},[167,169,170,171,172],{"id":49,"depth":168,"text":52},3,{"id":69,"depth":168,"text":72},{"id":80,"depth":168,"text":83},{"id":91,"depth":168,"text":94},{"id":102,"depth":168,"text":105},{"id":118,"depth":163,"text":121},{"id":145,"depth":163,"text":148},"markdown","content:blog:2-my-vscode-setup.md","content","blog/2-my-vscode-setup.md","blog/2-my-vscode-setup","md",[182,183],null,{"_path":184,"headline":185,"abstract":186},"/blog/1-my-first-blog-post","Introduction to My Blog","Discover why I started this blog, what you can expect, and how we can connect as a community.",{"_path":188,"_dir":8,"_draft":7,"_partial":7,"_locale":8,"mubaidr":189,"_id":198,"_type":199,"title":200,"_source":177,"_file":201,"_stem":202,"_extension":199},"/authors",{"@context":190,"@id":15,"@type":191,"alternateName":192,"gender":193,"image":194,"jobTitle":195,"name":14,"nation