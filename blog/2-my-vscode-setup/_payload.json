[{"data":1,"prerenderedAt":331},["ShallowReactive",2],{"content-/blog/2-my-vscode-setup":3,"home":197,"content-query-qKssHOB7DJ":214},{"article":4,"surround":192},{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"headline":11,"date":12,"dateUpdated":8,"author":13,"authorUrl":14,"socialImage":15,"body":21,"_type":186,"_id":187,"_source":188,"_file":189,"_stem":190,"_extension":191},"/blog/2-my-vscode-setup","blog",false,"","My VSCode Setup | Blog","Explore my minimalist VSCode setup featuring the Minimal Mist theme and settings for a clean, distraction-free coding environment.","My VSCode Setup","2024-07-17T12:00:00","Muhammad Ubaid Raza","https://mubaidr.js.org/",{"src":16,"mime":17,"alt":18,"width":19,"height":20},"/img/blog/2-my-vscode-setup/typescript-dark.png","png","Workplace Screenshot",1200,630,{"type":22,"children":23,"toc":173},"root",[24,32,38,45,52,66,72,77,83,88,94,99,105,110,115,121,126,133,142,148,161],{"type":25,"tag":26,"props":27,"children":29},"element","h1",{"id":28},"my-vscode-setup",[30],{"type":31,"value":11},"text",{"type":25,"tag":33,"props":34,"children":35},"p",{},[36],{"type":31,"value":37},"Hello, fellow developers! I’m Muhammad Ubaid Raza, and I want to share my latest VSCode setup with you. I've crafted this environment to be as minimalist and distraction-free as possible, and I call it Minimal Mist. This theme and setup have greatly enhanced my coding experience, and I hope it can do the same for you.",{"type":25,"tag":39,"props":40,"children":42},"h2",{"id":41},"features-of-minimal-mist",[43],{"type":31,"value":44},"Features of Minimal Mist",{"type":25,"tag":46,"props":47,"children":49},"h3",{"id":48},"subtle-background",[50],{"type":31,"value":51},"Subtle Background",{"type":25,"tag":33,"props":53,"children":54},{},[55,57,64],{"type":31,"value":56},"I chose a soft and soothing background color ",{"type":25,"tag":58,"props":59,"children":61},"code",{"className":60},[],[62],{"type":31,"value":63},"#f6f5f0",{"type":31,"value":65},". This subtle hue reduces eye strain and creates a calm coding environment, perfect for long coding sessions.",{"type":25,"tag":46,"props":67,"children":69},{"id":68},"shadow-free-design",[70],{"type":31,"value":71},"Shadow-Free Design",{"type":25,"tag":33,"props":73,"children":74},{},[75],{"type":31,"value":76},"In my quest for a cleaner interface, I disabled shadows. This makes the interface feel lighter and less cluttered, allowing me to focus more on my code.",{"type":25,"tag":46,"props":78,"children":80},{"id":79},"streamlined-borders",[81],{"type":31,"value":82},"Streamlined Borders",{"type":25,"tag":33,"props":84,"children":85},{},[86],{"type":31,"value":87},"Borders can often add unnecessary visual noise, so I simplified, minimized, or removed them. This provides a clean and focused workspace that helps keep distractions at bay.",{"type":25,"tag":46,"props":89,"children":91},{"id":90},"clean-look",[92],{"type":31,"value":93},"Clean Look",{"type":25,"tag":33,"props":95,"children":96},{},[97],{"type":31,"value":98},"Overall, the goal is a refined, distraction-free interface that lets me concentrate on what matters most - the code.",{"type":25,"tag":46,"props":100,"children":102},{"id":101},"unified-design",[103],{"type":31,"value":104},"Unified Design",{"type":25,"tag":33,"props":106,"children":107},{},[108],{"type":31,"value":109},"The dark theme maintains the same streamlined, shadow-free design and simplified borders for a cohesive look.",{"type":25,"tag":33,"props":111,"children":112},{},[113],{"type":31,"value":114},"Minimal Mist, both in light and dark variants, is perfect for developers who value a clean, minimalist aesthetic.",{"type":25,"tag":39,"props":116,"children":118},{"id":117},"preview",[119],{"type":31,"value":120},"Preview",{"type":25,"tag":33,"props":122,"children":123},{},[124],{"type":31,"value":125},"Here’s a preview of what you can expect:",{"type":25,"tag":127,"props":128,"children":130},"h4",{"id":129},"typescript",[131],{"type":31,"value":132},"Typescript",{"type":25,"tag":33,"props":134,"children":135},{},[136],{"type":25,"tag":137,"props":138,"children":141},"img",{"alt":139,"src":140},"Typescript Light","/img/blog/2-my-vscode-setup/typescript-light.png",[],{"type":25,"tag":39,"props":143,"children":145},{"id":144},"my-vscode-settings",[146],{"type":31,"value":147},"My VsCode Settings",{"type":25,"tag":33,"props":149,"children":150},{},[151,153,159],{"type":31,"value":152},"To further enhance the workspace setup, I use the following settings to reduce clutter and make my workspace even more minimal without sacrificing any functionality. You can add these settings to your ",{"type":25,"tag":58,"props":154,"children":156},{"className":155},[],[157],{"type":31,"value":158},"settings.json",{"type":31,"value":160}," file in VSCode to achieve the same look as in the screenshots above:",{"type":25,"tag":162,"props":163,"children":168},"pre",{"className":164,"code":166,"language":167,"meta":8},[165],"language-jsonc","\"editor.renderLineHighlight\": \"none\",\n\"editor.scrollbar.vertical\": \"hidden\",\n\"window.commandCenter\": false,\n\"window.menuBarVisibility\": \"compact\",\n\"window.titleBarStyle\": \"custom\",\n\"workbench.editor.tabActionCloseVisibility\": false,\n\"workbench.editor.tabSizing\": \"fixed\",\n\"workbench.editor.tabSizingFixedMaxWidth\": 240,\n\"workbench.editor.tabSizingFixedMinWidth\": 180,\n\"workbench.sideBar.location\": \"right\",\n\"workbench.statusBar.visible\": false,\n\"workbench.tree.indent\": 22,\n\"workbench.tree.renderIndentGuides\": \"none\",\n","jsonc",[169],{"type":25,"tag":58,"props":170,"children":171},{"__ignoreMap":8},[172],{"type":31,"value":166},{"title":8,"searchDepth":174,"depth":174,"links":175},2,[176,184,185],{"id":41,"depth":174,"text":44,"children":177},[178,180,181,182,183],{"id":48,"depth":179,"text":51},3,{"id":68,"depth":179,"text":71},{"id":79,"depth":179,"text":82},{"id":90,"depth":179,"text":93},{"id":101,"depth":179